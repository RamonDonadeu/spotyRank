# Copy to .env and fill in from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_client_id
# Must match a Redirect URI in your Spotify app (exact string, including host and path).
# Local dev (HTTP): pick the host you browse with — localhost and 127.0.0.1 are different.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/login/callback
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/login/callback

# Optional: skip OAuth and use mock library data
# VITE_SPOTIFY_MOCK=true
